# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=your_whatsapp_token_here
PHONE_NUMBER_ID=your_phone_number_id_here
VERIFY_TOKEN=your_chosen_verify_token_here

# Database
DATABASE_URL=postgresql://user:password@host:5432/farmsmart

# Africa's Talking SMS (optional fallback)
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_africastalking_username

# NASA EarthData (optional — improves soil moisture accuracy)
EARTHDATA_TOKEN=your_earthdata_token_here

# App
APP_ENV=development
LOG_LEVEL=INFO

# Telegram bot (optional — alternative to WhatsApp, instant setup)
# Get token from @BotFather on Telegram
TELEGRAM_TOKEN=123456:ABC-DEF1234

# Admin alerts (optional — Slack webhook for error notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz